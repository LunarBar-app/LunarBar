    "NSAppleEventsUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar uses Apple Events to reveal the selected date in the Calendar app.\n\nWithout this permission, LunarBar can still open the Calendar app, but it won’t be able to jump to the selected date.\n\nYou can change this anytime in System Settings, this dialog won’t appear again."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar 使用 Apple 事件在日历应用中定位所选日期。\n\n没有此权限时，LunarBar 仍可打开日历应用，但无法跳转到所选日期。\n\n您可以随时在系统设置中更改，此弹窗将不再出现。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar 使用 Apple 事件在日曆應用中定位所選日期。\n\n沒有此許可權時，LunarBar 仍可開啟日曆應用，但無法跳轉到所選日期。\n\n您可以隨時在系統設定中更改，此彈窗將不再出現。"
          }
        }
      }
    },
    "NSCalendarsFullAccessUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar uses your calendars to show events alongside each date.\n\nWithout this permission, LunarBar still works, but features that rely on the Calendar app won’t be available.\n\nYou can change this anytime in System Settings, this dialog won’t appear again."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar 使用您的日历，在每个日期旁显示事件。\n\n没有此权限时，LunarBar 仍可正常使用，但依赖日历应用的功能将不可用。\n\n您可以随时在系统设置中更改，此弹窗将不再出现。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar 使用您的日曆，在每個日期旁顯示事件。\n\n沒有此許可權時，LunarBar 仍可正常使用，但依賴日曆應用的功能將不可用。\n\n您可以隨時在系統設定中更改，此彈窗將不再出現。"
          }
        }
      }
    },
    "NSCalendarsUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar uses your calendars to show events alongside each date.\n\nWithout this permission, LunarBar still works, but features that rely on the Calendar app won’t be available.\n\nYou can change this anytime in System Settings, this dialog won’t appear again."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar 使用您的日历，在每个日期旁显示事件。\n\n没有此权限时，LunarBar 仍可正常使用，但依赖日历应用的功能将不可用。\n\n您可以随时在系统设置中更改，此弹窗将不再出现。"
