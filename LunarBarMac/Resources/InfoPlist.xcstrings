    "NSHumanReadableCopyright" : {
      "comment" : "Copyright (human-readable)",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "A bright moon rises over the sea, sharing this moment, though worlds apart."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "海上生明月，天涯共此时。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "海上生明月，天涯共此時。"
          }
        }
      }
    },
    "NSRemindersFullAccessUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar uses your reminders to show them alongside each date.\n\nThis is optional. You can change it anytime in System Settings, this dialog won’t appear again."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar 使用您的提醒事项，在每个日期旁显示它们。\n\n此为可选功能，您可以随时在系统设置中更改，此弹窗将不再出现。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LunarBar 使用您的提醒事項，在每個日期旁顯示它們。\n\n此為可選功能，您可以隨時在系統設定中更改，此彈窗將不再出現。"
          }
        }
      }
    },
